modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "NODE_ENV=production npx tsx server.ts"]
build = ["bash", "-c", "npm install --include=dev && npm run build"]
publicDir = "dist"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx server.ts & npx vite"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
LEADS_ADMIN_TOKEN = "ff228f4a7f2fe4196b82086445faf692e8b075d2d55c80972e0c7b5f98f2bd3e"

[userenv.production]
NODE_ENV = "production"
