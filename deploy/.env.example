# cttruckshop.com runtime secrets — TEMPLATE ONLY.
#
# The REAL .env lives on the VPS at /opt/sites/website-cttruckshop/.env
# and is NEVER committed to git. This file documents what variables the
# site expects so a new operator can populate them.
#
# Copy this template to the VPS:
#   scp deploy/.env.example root@vps:/opt/sites/website-cttruckshop/.env.example
#   ssh root@vps "cp /opt/sites/website-cttruckshop/.env.example /opt/sites/website-cttruckshop/.env && chmod 600 /opt/sites/website-cttruckshop/.env"
#   # then edit /opt/sites/website-cttruckshop/.env with real values
#
# After updating, restart any process that reads .env (the leads server
# in server.ts if it's running; the static Caddy serve doesn't need any).

# ─── Leads API (server.ts) ─────────────────────────────────────────────
# Postgres connection string for the leads-capture endpoint. Only needed
# if you run `node server.ts` separately from the static site.
DATABASE_URL=postgres://user:pass@host:5432/leads

# Admin token for hitting protected leads endpoints (e.g. GET /api/leads).
LEADS_ADMIN_TOKEN=

# ─── Email notifications ───────────────────────────────────────────────
# Resend API key for lead-form -> email notifications. The lead form on the
# site posts to a webhook/server.ts; whichever side calls Resend needs this.
RESEND_API_KEY=

# Where lead notifications go (comma-separated supported).
LEADS_NOTIFY_EMAIL=service@clevertranscoshop.com

# ─── Analytics & verification ──────────────────────────────────────────
# These are embedded at build time in index.html (already hard-coded there
# today). Documented here for awareness — if you rotate them, update the
# index.html meta tag and any GA4 / Search Console config.
#
# GA4 measurement ID:           G-B8RBZV56PW       (in index.html)
# GSC verification meta:        JcYfJEYN9ogZRj7gY2uq5V3yauER_8BM4ZV22nTzmcs (in index.html)

# ─── Optional: GSC service account (for SEO pipeline runs) ─────────────
# The pipeline at /opt/seo-pipeline/ uses a shared service account at
# /opt/seo-pipeline/credentials/gsc-sa.json with multi-site access. No
# per-site service account is required as long as the shared one has
# siteOwner / siteFullUser access to https://cttruckshop.com/ in GSC.
